# Virtual environment
.venv/
venv/
ENV/
.env

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Python bytecode
__pycache__/
*.pyc
*.pyo
*.pyd

# Datasets and archives
data/
*.zip
*.tar.gz

# Saved models — binaries untracked, registry manifests/JSON tracked
models/
!models/registry/
models/registry/**/*.joblib
!tests/fixtures/*.parquet
*.pkl

# Benchmark history stays tracked; pytest/ruff caches don't
.pytest_cache/
.ruff_cache/
*.egg-info/
